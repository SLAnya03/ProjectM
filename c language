#include <stdio.h>

int main() {
    int n;

    while (1) {
        printf("Enter a number (0 to stop): ");
        scanf("%d", &n);

        if (n == 0) {
            break; // exit the loop if user enters 0
        }

        if (n <= 1) {
            printf("%d is NOT prime\n", n);
        } else {
            int cnt = 0;

            for (int i = 1; i <= n; i++) {
                if (n % i == 0)
                    cnt++;
            }

            if (cnt > 2)
                printf("%d is NOT prime\n", n);
            else
                printf("%d is prime\n", n);
        }
    }

    return 0;
}
